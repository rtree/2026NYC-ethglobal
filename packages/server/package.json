{
  "name": "@intentos/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "smoke": "node dist/scripts/smoke.js",
    "owner:unfreeze": "tsx src/scripts/owner-unfreeze.ts"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^5.6.0",
    "@intentos/runtime": "workspace:*",
    "@intentos/shared": "workspace:*",
    "@worldcoin/idkit-core": "^4.1.8",
    "google-auth-library": "^9.15.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
