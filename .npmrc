# Supply-chain hardening for this repo (pnpm). See .github/copilot-instructions.md.
# Block lifecycle scripts (preinstall/install/postinstall) by default.
ignore-scripts=true
# Run vulnerability audit on install.
audit=true
# npm-only knob (pnpm ignores it; pnpm uses minimumReleaseAge in pnpm-workspace.yaml).
# Unit is DAYS. Block packages published less than 7 days ago.
min-release-age=7
